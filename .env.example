# InsForge backend
NEXT_PUBLIC_INSFORGE_URL=https://<appkey>.<region>.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=<anon-key>

# Server-only (never expose to the client)
INSFORGE_API_KEY=<service-api-key>

# 32+ byte random string used to salt ip/ua hashes for dedup
IP_HASH_SALT=<random-bytes>

# Used by the redirect to build absolute short URLs when needed
NEXT_PUBLIC_APP_URL=http://localhost:3000
